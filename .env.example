# ============================================
# VRIKAAN - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Firebase Configuration ----
# Get these from: https://console.firebase.google.com
# 1. Create a project
# 2. Go to Project Settings > General > Your Apps > Add Web App
# 3. Copy the config values
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ---- Firebase Auth Providers to Enable ----
# Go to Firebase Console > Authentication > Sign-in method
# Enable these providers:
# 1. Email/Password
# 2. Google (add your domain to authorized domains)
# 3. GitHub (create OAuth app at github.com/settings/developers, add callback URL from Firebase)
# 4. Facebook (create app at developers.facebook.com, add callback URL from Firebase)
# 5. Phone (enable phone auth, add test phone numbers if needed)

# ---- EmailJS Configuration ----
# Get these from: https://www.emailjs.com
# 1. Create account
# 2. Add email service (Gmail, Outlook, etc.)
# 3. Create email templates for welcome, payment, password reset
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_WELCOME_TEMPLATE=your_welcome_template_id
VITE_EMAILJS_PAYMENT_TEMPLATE=your_payment_template_id
VITE_EMAILJS_PASSWORD_RESET_TEMPLATE=your_password_reset_template_id

# ---- Razorpay (for Indian payments) ----
# Get from: https://dashboard.razorpay.com
# 1. Complete KYC verification
# 2. Go to Settings > API Keys > Generate Key
# Use rzp_test_ keys for testing, rzp_live_ keys for production
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_id

# ---- Groq AI API Key ----
VITE_GROQ_API_KEY=your_groq_api_key
